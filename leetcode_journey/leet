class Solution:
    def reverseVowels(self, s: str) -> str:
        v=set("aeiouAEIOU")
        ch=list(s)
        l,r=0,len(ch)-1
        while l<r:
            while l<r and ch[l] not in v:
                l+=1
            while l<r and ch[r] not in v:
                r-=1
            ch[l],ch[r]=ch[r],ch[l]
            l+=1
            r-=1
        return "".join(ch)

