4.https://leetcode.com/problems/valid-sudoku/

class Solution:
    def isValidSudoku(self, board: List[List[str]]) -> bool:
        rows=set()
        cols=set()
        box=set()
        for r in range(9):
            for c in range(9):
                num=board[r][c]
                if num==".":
                    continue
                if (r,num) in rows:
                    return False
                if(c,num)in cols:
                    return False
                if(r//3,c//3,num)in box:
                    return False
                rows.add((r,num))
                cols.add((c,num))
                box.add((r//3,c//3,num))
        return True

