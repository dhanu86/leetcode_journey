class Solution:
    def rotate(self, nums: List[int], k: int) -> None:
        n=len(nums)
        k=k%n
        for i in range(k):
            t=nums[n-1]
            for i in range(n-1,0,-1):
                nums[i]=nums[i-1]
            nums[0]=t


